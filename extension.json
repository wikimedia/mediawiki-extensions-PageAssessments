{
	"name": "PageAssessments",
	"version": "1.1.0",
	"author": [
		"Niharika Kohli",
		"Frances Hocutt",
		"Ryan Kaldari",
		"Sam Wilson"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:PageAssessments",
	"descriptionmsg": "pageassessments-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "parserhook",
	"requires": {
		"MediaWiki": ">= 1.46"
	},
	"APIListModules": {
		"projectpages": {
			"class": "MediaWiki\\Extension\\PageAssessments\\Api\\ApiQueryProjectPages",
			"services": [
				"PageAssessments.Store"
			]
		},
		"projects": "MediaWiki\\Extension\\PageAssessments\\Api\\ApiQueryProjects"
	},
	"APIPropModules": {
		"pageassessments": "MediaWiki\\Extension\\PageAssessments\\Api\\ApiQueryPageAssessments"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\PageAssessments\\": "src/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\PageAssessments\\Tests\\": "tests/phpunit/"
	},
	"ExtensionMessagesFiles": {
		"PageAssessmentsMagic": "PageAssessments.i18n.magic.php",
		"PageAssessmentsAlias": "PageAssessments.i18n.alias.php"
	},
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"Hooks": {
		"ParserFirstCallInit": "parser",
		"LoadExtensionSchemaUpdates": "schema",
		"LinksUpdateComplete": "parser",
		"CirrusSearchAddQueryFeatures": "cirrussearch"
	},
	"HookHandlers": {
		"parser": {
			"class": "MediaWiki\\Extension\\PageAssessments\\HookHandler\\ParserHooks",
			"services": [
				"PageAssessments.Store",
				"NamespaceInfo",
				"MainConfig"
			]
		},
		"schema": {
			"class": "MediaWiki\\Extension\\PageAssessments\\HookHandler\\SchemaHooks"
		},
		"cirrussearch": {
			"class": "MediaWiki\\Extension\\PageAssessments\\HookHandler\\CirrusSearchHooks"
		}
	},
	"DomainEventIngresses": [
		{
			"events": [
				"PageDeleted"
			],
			"class": "MediaWiki\\Extension\\PageAssessments\\EventIngress",
			"services": [
				"PageAssessments.Store"
			]
		}
	],
	"MessagesDirs": {
		"PageAssessments": [
			"i18n",
			"i18n/api"
		]
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "examples/PageAssessments"
	},
	"ResourceModules": {
		"ext.pageassessments.special": {
			"scripts": "modules/ext.pageassessments.special.js",
			"dependencies": [
				"oojs-ui-core",
				"jquery.suggestions"
			]
		}
	},
	"SpecialPages": {
		"PageAssessments": "MediaWiki\\Extension\\PageAssessments\\SpecialPage"
	},
	"config": {
		"PageAssessmentsOnTalkPages": {
			"value": true
		},
		"PageAssessmentsSubprojects": {
			"value": false
		}
	},
	"attributes": {
		"Scribunto": {
			"LuaExtraTitleAttributes": {
				"pageAssessments": {
					"class": "MediaWiki\\Extension\\PageAssessments\\LuaProjectsAttributeResolver",
					"services": [
						"PageAssessments.Store",
						"MainConfig"
					]
				}
			}
		}
	},
	"manifest_version": 2
}
